# QuantLuna — Environment Variables
# Copiaza in .env si completeaza cu valorile tale
# NICIODATA nu comite .env in git!

# ============================================================
# EXCHANGE SETTINGS
# ============================================================
EXCHANGE=bybit
EXCHANGE_MODE=paper       # paper | dry | live

# ============================================================
# BYBIT API
# ============================================================
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=false
BYBIT_CATEGORY=linear

# ============================================================
# BYBIT PRIVATE WEBSOCKET (Sprint 31 — R)
# ============================================================
BYBIT_PRIVATE_WS_URL=wss://stream.bybit.com/v5/private
# BYBIT_PRIVATE_WS_URL=wss://stream-testnet.bybit.com/v5/private  # testnet

# ============================================================
# BINANCE API (optional)
# ============================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ============================================================
# TELEGRAM ALERTS
# ============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ENABLED=true

# ============================================================
# DISCORD ALERTS
# ============================================================
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
DISCORD_ENABLED=true

# ============================================================
# ALERT THRESHOLDS
# ============================================================
ALERT_DD_THRESHOLD=0.08
ALERT_SHARPE_THRESHOLD=0.5

# ============================================================
# DATA CACHE
# ============================================================
DATA_CACHE_DIR=data/cache

# ============================================================
# RISK + SIZING
# ============================================================
INITIAL_CAPITAL_USD=10000
SHARPE_WINDOW=30
MAX_LEVERAGE=3.0
KELLY_FRACTION=half
MAX_POSITION_PCT=0.25

# ============================================================
# CORRELATION FILTER
# ============================================================
CORR_FILTER_THRESHOLD=0.80
CORR_FILTER_WINDOW=60

# ============================================================
# MULTI-PAIR MANAGER
# ============================================================
MAX_PAIRS=5

# ============================================================
# AUTO-REBALANCER
# ============================================================
REBALANCER_ENABLED=true
REBALANCER_INTERVAL_H=24     # ore intre rebalansari automate
REBALANCER_MIN_ALLOC_PCT=0.05 # min 5% per pereche
REBALANCER_MAX_ALLOC_PCT=0.40 # max 40% per pereche

# ============================================================
# REPORTS (Sprint 31 — S)
# ============================================================
REPORTS_DIR=data/reports      # director unde se salveaza rapoartele HTML/PDF

# ============================================================
# MULTI-STRATEGY ENGINE (Sprint 31 — T)
# ============================================================
STRATEGY_CAPITAL_SPLIT=equal  # equal | sharpe_prop | manual
STRATEGY_CONFLICT_RESOLUTION=best_of  # best_of | ignore
STRATEGY_REALLOC_INTERVAL_H=6  # ore intre realocari capital

# ============================================================
# AI/ML SIGNAL LAYER (Sprint 47)
# ============================================================
ML_ENABLED=false                         # true = activeaza ML signal layer
ML_COLLECT_ONLY=false                    # true = colecteaza features fara predictii
ML_FEATURE_LOOKBACK=100                  # bare pentru rolling feature computation
ML_WARMUP_BARS=200                       # bare minime inainte de inferenta
ML_RETRAIN_INTERVAL=500                  # bare intre retrain online
ML_LR_RATE=0.01                          # learning rate logistic regression
ML_LR_L2=0.001                           # L2 regularisation logistic
ML_LIN_RATE=0.005                        # learning rate linear regression
ML_LIN_L2=0.001                          # L2 regularisation linear
ML_MAX_MODELS=3                          # nr maxim modele per tip in registry
ML_WEIGHT_MIN=0.0                        # pondere minima ML in fusion
ML_WEIGHT_MAX=0.5                        # pondere maxima ML in fusion
ML_Z_WEIGHT_MIN=0.5                      # pondere minima Z-score in fusion
ML_Z_WEIGHT_MAX=1.0                      # pondere maxima Z-score in fusion
ML_CONF_THRESHOLD=0.3                    # prag minim confidenta ML
ML_FUSION_THRESHOLD=0.3                  # prag entry fused signal
ML_TRENDING_W=0.40                       # pondere ML in regim trending
ML_RANGING_W=0.15                        # pondere ML in regim ranging
ML_BREAKOUT_W=0.50                       # pondere ML in regim breakout
ML_UNKNOWN_W=0.20                        # pondere ML in regim unknown
ML_CHECKPOINT_DIR=data/models/           # director pentru salvare modele

# ============================================================
# DASHBOARD
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL=https://your-api-domain.com  # productie

# ============================================================
# API SERVER
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ============================================================
# S48: KALMAN + PROFIT GUARD (Bug fixes + Profit protection)
# ============================================================
KALMAN_ENABLED=true                       # activeaza Kalman filter (real z-scores)
PROFIT_GUARD_ENABLED=true                 # activeaza ProfitGuard (TP, trailing, ladder)
KALMAN_DELTA=0.0001                       # process noise Kalman
KALMAN_WINDOW=200                         # z-score rolling window
