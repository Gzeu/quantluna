# QuantLuna — Environment Variables
# Copiaza in .env si completeaza cu valorile tale
# NICIODATA nu comite .env in git!

# ============================================================
# EXCHANGE SETTINGS
# ============================================================
# Exchange activ: bybit | binance
EXCHANGE=bybit

# Mod de rulare: paper | dry | live
# paper = simulare locala, fara ordine reale
# dry   = loguri fara executie pe exchange
# live  = ordine reale (ATENTIE!)
EXCHANGE_MODE=paper

# ============================================================
# BYBIT API (principale)
# ============================================================
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# Testnet Bybit: true | false
BYBIT_TESTNET=false

# Categoria Bybit: spot | linear | inverse
# linear = USDT Perpetual (recomandat pentru pairs trading)
BYBIT_CATEGORY=linear

# ============================================================
# BINANCE API (secundar / optional)
# ============================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# Override URL pentru testnet Binance
BINANCE_BASE_URL=https://api.binance.com

# ============================================================
# NOTIFICATIONS
# ============================================================
# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Discord webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
DISCORD_ENABLED=true

# ============================================================
# DATA CACHE
# ============================================================
DATA_CACHE_DIR=data/cache

# ============================================================
# RISK SETTINGS
# ============================================================
# Capital initial portfolio (USD)
INITIAL_CAPITAL_USD=10000

# Sharpe rolling window (numar de tranzactii)
SHARPE_WINDOW=30

# ============================================================
# MULTI-PAIR MANAGER
# ============================================================
# Numar maxim de perechi simultane
MAX_PAIRS=5

# ============================================================
# API SERVER
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
