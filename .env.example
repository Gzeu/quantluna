# QuantLuna — Environment Variables
# Copiaza ca .env si completeaza cu datele tale
# cp .env.example .env
#
# !! ATENTIE: Nu comite niciodata .env in git !!
# Toate valorile de mai jos sunt EXEMPLE / defaults sigure.

# ============================================================
# Exchange (obligatoriu pentru live)
# ============================================================

EXCHANGE=bybit
EXCHANGE_MODE=live           # paper | dry | live

# Bybit
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=false           # true = testnet
BYBIT_CATEGORY=linear         # linear | inverse | spot

# Binance (optional, daca EXCHANGE=binance)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OKX (optional, daca EXCHANGE=okx)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_SANDBOX=false

# ============================================================
# Trading — Pereche si parametri
# ============================================================

# Pereche trading (folosite de BybitLiveRunnerConfig)
SYMBOL_Y=BTCUSDT
SYMBOL_X=ETHUSDT

# Interval bara (minute): 1 | 3 | 5 | 15 | 30 | 60 | 240 | 1440
INTERVAL=5

# false = ordine reale trimise la exchange
DRY_RUN=false

# ============================================================
# Strategie Kalman / Z-score
# ============================================================

WARMUP_BARS=100               # bare necesare pentru warm-up (min 20)
KALMAN_WINDOW=200             # fereastra Kalman Filter
HALF_LIFE_H=24.0              # half-life mean-reversion (ore)

ENTRY_ZSCORE=2.0              # z-score entry threshold (trebuie > 0)
EXIT_ZSCORE=0.5               # z-score exit threshold (trebuie < ENTRY_ZSCORE)
BASE_QTY=0.01                 # cantitate de baza (unitati symbol_y, trebuie > 0)

# ============================================================
# Risk Management
# ============================================================

MAX_CONSEC_LOSSES=3           # circuit breaker: pierderi consecutive
MAX_DRAWDOWN_PCT=10.0         # circuit breaker: drawdown maxim % (valid: 0 < x <= 100)
COOLDOWN_SECONDS=300          # cooldown dupa circuit breaker (secunde)

FUNDING_GATE_ENABLED=true     # blocheaza intrari cand funding rate < -1%
PNL_RECONCILER_ENABLED=true
MARKET_TRADE_ENABLED=true

# ============================================================
# Stop-Loss / Take-Profit Nativ Bybit
# Bybit gestioneaza SL/TP chiar daca procesul cade
# ============================================================

NATIVE_SL_TP_ENABLED=true    # false = dezactiveaza SL/TP nativ
SL_PCT=0.03                   # 3% stop-loss de la entry price
TP_PCT=0.06                   # 6% take-profit de la entry price

# ============================================================
# Private WebSocket — Fill-uri instant
# Fills vin prin WS privat, nu prin polling REST la 60s
# ============================================================

PRIVATE_WS_ENABLED=true      # false = dezactiveaza (foloseste doar REST polling)

# ============================================================
# REST Warm-up (Phase 0)
# ============================================================

REST_WARMUP_ENABLED=true      # false = salt direct la WS warm-up

# ============================================================
# Notifications
# ============================================================

# Telegram (recomandat — alerte trade + circuit breaker + fill-uri instant)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack
SLACK_WEBHOOK_URL=

# Discord
DISCORD_WEBHOOK_URL=

# ============================================================
# Dashboard & Health
# ============================================================

DASHBOARD_PORT=8000           # port FastAPI dashboard
HEALTH_PORT=8081              # port HTTP health check runner
QUANTLUNA_DB_PATH=data/quantluna_jobs.db

# ============================================================
# Paths
# ============================================================

DATA_DIR=data
# fix #21: STATE_DIR si LOG_DIR pot fi override-uite pentru Docker volumes
STATE_DIR=state               # director pentru checkpoint-uri si fisiere de stare
LOG_DIR=logs                  # director pentru fisiere log rotate
LOGS_DIR=logs                 # alias pastrat pentru compatibilitate
CHECKPOINT_PATH=state/position_checkpoint.db
BEST_PARAMS_PATH=state/best_params.json

# ============================================================
# Runner Timeout (fix #20)
# Hard timeout (secunde) inainte de force-cancel.
# 0 = fara timeout (infinit, nerecomandat in productie).
# ============================================================

RUNNER_TIMEOUT_SECONDS=7200   # default 2h; mariti pentru strategii cu holding lung

# ============================================================
# State Bus
# ============================================================

STATE_BUS_PUBLISH_INTERVAL=1  # publica in state_bus la fiecare N bare

# ============================================================
# Backtest / Optimize
# ============================================================

BACKTEST_DAYS=90
TIMEFRAME=1h
OPT_TRIALS=200
OPT_OBJECTIVE=sharpe

# ============================================================
# Logging
# ============================================================

LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/quantluna.log

# ============================================================
# Monitoring Watchdog — MonitoringWatchdog.from_env()
# ============================================================

WATCHDOG_ENABLED=true                 # false => watchdog nu porneste
WATCHDOG_CHECK_INTERVAL=60            # secunde intre verificari (default 60)
WATCHDOG_SHARPE_MIN=0.3               # sharpe rolling 24h sub care alertam
WATCHDOG_MAX_DD=0.10                  # drawdown maxim fractie (0.10 = 10%)
WATCHDOG_Z_MAX=4.0                    # |z-score| maxim acceptat
WATCHDOG_HL_MAX=96                    # half-life maxim (ore)

# ============================================================
# Optimizer — ParamGridOptimizer / AutoReoptimizer
# ============================================================

OPTIMIZER_ENABLED=true                # false => AutoReoptimizer dezactivat
OPTIMIZER_BACKEND=param_grid          # param_grid | optuna
OPTIMIZER_MAX_COMBINATIONS=500        # max combinatii grid search
OPTIMIZER_REOPTIMIZE_INTERVAL_HOURS=24  # interval re-optimizare (ore)
OPTIMIZER_MIN_TRADES_FOR_REOPT=50     # nr minim tranzactii pentru trigger
OPTIMIZER_METRIC=sharpe               # sharpe | calmar | pnl
