# QuantLuna — Environment Variables
# Copiaza in .env si completeaza cu valorile tale
# NICIODATA nu comite .env in git!

# ============================================================
# EXCHANGE SETTINGS
# ============================================================
# Exchange activ: bybit | binance
EXCHANGE=bybit

# Mod de rulare: paper | dry | live
# paper = simulare locala, fara ordine reale
# dry   = loguri fara executie pe exchange
# live  = ordine reale pe Bybit (ATENTIE!)
EXCHANGE_MODE=paper

# ============================================================
# BYBIT API
# ============================================================
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# Testnet: true | false (recomandat true pentru teste initiale)
BYBIT_TESTNET=false

# Categoria: spot | linear | inverse
# linear = USDT Perpetual (recomandat pairs trading futures)
BYBIT_CATEGORY=linear

# Override URL (optional, default: https://api.bybit.com)
# BYBIT_BASE_URL=https://api-testnet.bybit.com

# ============================================================
# BINANCE API (secundar / optional)
# ============================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_BASE_URL=https://api.binance.com

# ============================================================
# NOTIFICATIONS
# ============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
DISCORD_ENABLED=true

# ============================================================
# DATA CACHE
# ============================================================
DATA_CACHE_DIR=data/cache

# ============================================================
# RISK + SIZING
# ============================================================
# Capital initial portfolio (USD)
INITIAL_CAPITAL_USD=10000

# Sharpe rolling window (numar de tranzactii)
SHARPE_WINDOW=30

# Leverage maxim permis per pozitie
MAX_LEVERAGE=3.0

# Kelly fraction: full | half | quarter (recomandat: half)
KELLY_FRACTION=half

# Max % capital per pozitie (0.25 = 25%)
MAX_POSITION_PCT=0.25

# ============================================================
# MULTI-PAIR MANAGER
# ============================================================
MAX_PAIRS=5

# ============================================================
# API SERVER
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
