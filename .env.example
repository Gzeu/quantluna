# QuantLuna — Environment Variables
# Copiaza ca .env si completeaza cu datele tale
# cp .env.example .env
#
# ATENTIE: Nu comite niciodata .env in git!

# ============================================================
# Exchange API Keys
# ============================================================

# Bybit (recomandat pentru start)
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=false

# Binance
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=false

# OKX
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_PASSPHRASE=your_okx_passphrase
OKX_SANDBOX=false

# ============================================================
# Trading Mode
# ============================================================

# true  = paper/dry-run (nu trimite ordine reale)
# false = live trading (ATENTIE: bani reali!)
DRY_RUN=true

# Exchange implicit
EXCHANGE=bybit

# Capital initial pentru paper trading ($USD)
CAPITAL_USD=10000

# Pereche implicita
SYM_Y=BTCUSDT
SYM_X=ETHUSDT

# Slippage estimat pentru paper trading (0.05% = 0.0005)
SLIPPAGE=0.0005

# ============================================================
# Notifications
# ============================================================

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_WEBHOOK_URL=

# Slack
SLACK_WEBHOOK_URL=

# ============================================================
# Dashboard
# ============================================================

DASHBOARD_PORT=8000
QUANTLUNA_DB_PATH=data/quantluna_jobs.db

# ============================================================
# Paths
# ============================================================

DATA_DIR=data
STATE_DIR=state
LOGS_DIR=logs

# ============================================================
# Backtest / Optimize
# ============================================================

BACKTEST_DAYS=90
TIMEFRAME=1h

# Numarul de trial-uri Optuna
OPT_TRIALS=200
OPT_OBJECTIVE=sharpe

# ============================================================
# Logging
# ============================================================

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Fisier log (optional, loguru rotatie automata)
LOG_FILE=logs/quantluna.log
