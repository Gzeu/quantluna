# ============================================================
# QuantLuna — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ---------------------------------------------------------------
# Exchange API Keys
# ---------------------------------------------------------------
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Paper trading mode (true = no real orders placed)
PAPER_TRADING=true

# ---------------------------------------------------------------
# Telegram Notifications
# ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ---------------------------------------------------------------
# Strategy — Pair
# ---------------------------------------------------------------
QUANTLUNA_SYM_Y=BTCUSDT
QUANTLUNA_SYM_X=ETHUSDT
QUANTLUNA_EXCHANGE=bybit
QUANTLUNA_BAR_FREQ=1h

# ---------------------------------------------------------------
# Strategy — Kalman Filter
# ---------------------------------------------------------------
QUANTLUNA_DELTA=0.0001
QUANTLUNA_OBSERVATION_NOISE=0.01
QUANTLUNA_WARM_UP_BARS=30

# ---------------------------------------------------------------
# Strategy — Signal
# ---------------------------------------------------------------
QUANTLUNA_ZSCORE_ENTRY=2.0
QUANTLUNA_ZSCORE_EXIT=0.5
QUANTLUNA_ZSCORE_WINDOW=100

# ---------------------------------------------------------------
# Strategy — Risk / Sizing
# ---------------------------------------------------------------
QUANTLUNA_KELLY_FRACTION=0.25
QUANTLUNA_VOL_TARGET=0.01
QUANTLUNA_CAPITAL_USDT=10000
QUANTLUNA_PORTFOLIO_HARD_DD=0.10
QUANTLUNA_HALF_LIFE_MIN_H=2.0
QUANTLUNA_HALF_LIFE_MAX_H=168.0

# ---------------------------------------------------------------
# Cointegration Tests  (prefix: QUANTLUNA_COINT_)
# ---------------------------------------------------------------
QUANTLUNA_COINT_ADF_ALPHA=0.05
QUANTLUNA_COINT_JOHANSEN_SIGNIF=0.05
QUANTLUNA_COINT_MIN_HALF_LIFE_H=2.0
QUANTLUNA_COINT_MAX_HALF_LIFE_H=168.0
QUANTLUNA_COINT_REQUIRE_BOTH_TESTS=false
QUANTLUNA_COINT_REQUIRE_HALF_LIFE=true
QUANTLUNA_COINT_REQUIRE_RESIDUALS=false
QUANTLUNA_COINT_EG_MIN_OBS=150

# ---------------------------------------------------------------
# Optuna Optimizer
# ---------------------------------------------------------------
OPTUNA_STORAGE=sqlite:///data/optuna.db
OPTUNA_STUDY_NAME=quantluna_opt

# ---------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_RELOAD=false

# ---------------------------------------------------------------
# Data
# ---------------------------------------------------------------
DATA_DIR=data/
LOG_DIR=logs/
LOG_LEVEL=INFO
