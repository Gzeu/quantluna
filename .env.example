# QuantLuna — Environment Variables
# Copiaza acest fisier in .env si completeaza valorile

# ============================================================
# Exchange credentials
# ============================================================
EXCHANGE=bybit                         # binance | bybit | okx
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=false

BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=false

# ============================================================
# Capital si risc
# ============================================================
MAX_CAPITAL_USDT=10000
MAX_LEVERAGE=3
MAX_RISK_PER_TRADE=0.01                # 1% risc per trade
MAX_DRAWDOWN=0.15                      # Oprire la -15% drawdown

# ============================================================
# Trading mode
# ============================================================
TRADING_MODE=paper                     # paper | live | testnet

# ============================================================
# Telegram alerts
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# Signal v4 — P0-1: Volatility-adjusted threshold
# ============================================================
VOL_ADJ_ENABLED=true
VOL_ADJ_FACTOR=0.40                    # Cat creste threshold-ul la vol maxima
VOL_ADJ_LOOKBACK=100                   # Bare pentru estimare vol percentile
VOL_ADJ_MAX_MULTIPLIER=1.6             # Cap: threshold nu depaseste 1.6x baza

# ============================================================
# Signal v4 — P0-2: Delta-z momentum filter
# ============================================================
DZ_FILTER_ENABLED=true
DZ_LOOKBACK=3                          # Bare pentru calculul derivatei z
DZ_BLOCK_RATIO=0.25                    # Blocheaza daca |dz_avg| > ratio * |z|

# ============================================================
# Signal v4 — P1-1: Dynamic cooldown
# ============================================================
DYNAMIC_COOLDOWN_ENABLED=true
COOLDOWN_HL_FACTOR=0.50               # cooldown = ceil(half_life * factor)
COOLDOWN_MIN=2
COOLDOWN_MAX=20

# ============================================================
# Signal v4 — P1-2: Partial exit la z=0
# ============================================================
PARTIAL_EXIT_ENABLED=true
PARTIAL_EXIT_PCT=0.50                  # % din pozitie inchis la partial exit
PARTIAL_EXIT_ZSCORE=0.0               # Z-score trigger

# ============================================================
# Adoption Engine (pozitii orfane la startup)
# ============================================================
ADOPT_MIN_PNL_PCT=-0.02               # Adopta daca PnL > -2%
CLOSE_LOSS_PCT=-0.05                  # Inchide imediat daca PnL < -5%
MIN_LIQ_DISTANCE_PCT=0.08             # Inchide daca distanta la lichidare < 8%
MIN_NOTIONAL_ADOPT=5.0                # Nu adopta pozitii sub 5 USDT

# ============================================================
# Profit Optimizer (pozitii adoptate)
# ============================================================
TP_TARGET_PCT=0.04                     # Take-Profit la +4%
SL_MAX_LOSS_PCT=0.03                   # Stop-Loss la -3% fata de entry
TRAILING_ACTIVATION_PCT=0.02          # Activeaza trailing stop la +2% profit
TRAILING_DISTANCE_PCT=0.015           # Trailing la 1.5% sub peak
OPTIMIZER_POLL_INTERVAL_S=1.0         # Interval poll price feed (secunde)

# ============================================================
# Cointegration re-test — P1-3
# ============================================================
COINT_RETEST_INTERVAL_HOURS=6
COINT_BLACKLIST_PVALUE=0.10

# ============================================================
# Database
# ============================================================
CHECKPOINT_DB=position_checkpoint.db

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/quantluna.log
