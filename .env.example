# QuantLuna — Environment Variables
# Copiaza in .env si completeaza cu valorile tale
# NICIODATA nu comite .env in git!

# ============================================================
# EXCHANGE SETTINGS
# ============================================================
EXCHANGE=bybit
EXCHANGE_MODE=paper       # paper | dry | live

# ============================================================
# BYBIT API
# ============================================================
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=false
BYBIT_CATEGORY=linear
# BYBIT_BASE_URL=https://api-testnet.bybit.com

# ============================================================
# BINANCE API (optional)
# ============================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ============================================================
# TELEGRAM ALERTS
# ============================================================
# Obtii token de la @BotFather pe Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID: trimite /start la bot, apoi GET /getUpdates
# Multiple chat_ids: separa cu virgula (ex: 123456789,987654321)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ENABLED=true

# ============================================================
# DISCORD ALERTS
# ============================================================
# Webhook URL: Discord Server Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
DISCORD_ENABLED=true

# ============================================================
# ALERT THRESHOLDS
# ============================================================
# DD Alert: trimite alerta cand drawdown > X%
ALERT_DD_THRESHOLD=0.08      # 8% drawdown
# Sharpe Drop: trimite alerta cand Sharpe rolling < X
ALERT_SHARPE_THRESHOLD=0.5

# ============================================================
# DATA CACHE
# ============================================================
DATA_CACHE_DIR=data/cache

# ============================================================
# RISK + SIZING
# ============================================================
INITIAL_CAPITAL_USD=10000
SHARPE_WINDOW=30
MAX_LEVERAGE=3.0
KELLY_FRACTION=half
MAX_POSITION_PCT=0.25

# ============================================================
# CORRELATION FILTER
# ============================================================
# Blocheaza perechi cu corelatie > threshold
CORR_FILTER_THRESHOLD=0.80
CORR_FILTER_WINDOW=60      # bare pentru calcul rolling

# ============================================================
# MULTI-PAIR MANAGER
# ============================================================
MAX_PAIRS=5

# ============================================================
# API SERVER
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
