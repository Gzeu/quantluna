# QuantLuna — Template PRODUCTIE
# cp .env.production.example .env
# !! Nu comite niciodata .env in git !!
#
# Toate variabilele marcate cu [REQUIRED] trebuie completate.
# Variabilele cu [OPTIONAL] pot fi lasate goale.

# ============================================================
# PRODUCTIE — setari critice
# ============================================================

DRY_RUN=false                        # [REQUIRED] false = ordine reale
EXCHANGE=bybit                       # [REQUIRED] bybit | binance | okx
EXCHANGE_MODE=live                   # [REQUIRED] live
LOG_LEVEL=INFO

# ============================================================
# API Keys — Exchange
# ============================================================

# Bybit [REQUIRED daca EXCHANGE=bybit]
BYBIT_API_KEY=                       # [REQUIRED]
BYBIT_API_SECRET=                    # [REQUIRED]
BYBIT_TESTNET=false                  # false = mainnet real
BYBIT_CATEGORY=linear

# Binance [OPTIONAL]
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OKX [OPTIONAL]
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_SANDBOX=false

# ============================================================
# Trading — Pereche si parametri
# ============================================================

SYMBOL_Y=BTCUSDT                    # [REQUIRED]
SYMBOL_X=ETHUSDT                    # [REQUIRED]
INTERVAL=5                          # minute: 1|3|5|15|30|60|240
BASE_QTY=0.01                       # cantitate baza symbol_y

# ============================================================
# Kalman / Z-score
# ============================================================

WARMUP_BARS=100
KALMAN_WINDOW=200
HALF_LIFE_H=24.0
ENTRY_ZSCORE=2.0
EXIT_ZSCORE=0.5

# ============================================================
# Risk Management
# ============================================================

MAX_CONSEC_LOSSES=3
MAX_DRAWDOWN_PCT=10.0
COOLDOWN_SECONDS=300

# Stop-Loss / Take-Profit nativ Bybit
NATIVE_SL_TP_ENABLED=true
SL_PCT=0.03
TP_PCT=0.06

# ============================================================
# WebSocket
# ============================================================

PRIVATE_WS_ENABLED=true
REST_WARMUP_ENABLED=true
RUNNER_TIMEOUT_SECONDS=7200

# ============================================================
# MonitoringWatchdog
# ============================================================

WATCHDOG_ENABLED=true
WATCHDOG_CHECK_INTERVAL=60
WATCHDOG_SHARPE_MIN=0.3
WATCHDOG_MAX_DD=0.10
WATCHDOG_Z_MAX=4.0
WATCHDOG_HL_MAX=96

# ============================================================
# AutoReoptimizer
# ============================================================

OPTIMIZER_ENABLED=true
OPTIMIZER_BACKEND=param_grid
OPTIMIZER_REOPTIMIZE_INTERVAL_HOURS=168   # saptamanal
OPTIMIZER_MIN_TRADES_FOR_REOPT=50
OPTIMIZER_METRIC=sharpe

# ============================================================
# Notifications [REQUIRED pentru alerte live]
# ============================================================

TELEGRAM_BOT_TOKEN=                 # [REQUIRED] alertele ajung pe Telegram
TELEGRAM_CHAT_ID=                   # [REQUIRED]
SLACK_WEBHOOK_URL=                  # [OPTIONAL]
DISCORD_WEBHOOK_URL=                # [OPTIONAL]

# ============================================================
# Dashboard & API
# ============================================================

DASHBOARD_PORT=8000
HEALTH_PORT=8081
QUANTLUNA_DB_PATH=data/quantluna_jobs.db

# URL-ul prin care Next.js contacteaza FastAPI
# In Docker productie: http://ql-api:8000 (pe reteaua interna)
# Sau prin nginx:       http://YOUR_DOMAIN/api
NEXT_PUBLIC_API_URL=http://ql-api:8000

# ============================================================
# Paths (Docker volumes)
# ============================================================

DATA_DIR=data
STATE_DIR=state
LOG_DIR=logs
LOGS_DIR=logs
CHECKPOINT_PATH=state/position_checkpoint.db
BEST_PARAMS_PATH=state/best_params.json

# ============================================================
# Misc
# ============================================================

FUNDING_GATE_ENABLED=true
PNL_RECONCILER_ENABLED=true
MARKET_TRADE_ENABLED=true
STATE_BUS_PUBLISH_INTERVAL=1
BACKTEST_DAYS=90
TIMEFRAME=1h
OPT_TRIALS=200
OPT_OBJECTIVE=sharpe
LOG_FILE=logs/quantluna.log
