# QuantLuna .dockerignore
# Exclude din Docker build context pentru imagini mai mici si mai sigure

# Secrets — NICIODATA in imagine!
.env
.env.*
!.env.example
*.pem
*.key

# Data & state — montate ca volume
data/
state/
logs/
*.db
*.sqlite

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Type checker cache
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# Git
.git/
.gitignore

# Docs
docs/
*.md
!README.md

# CI
.github/

# Jupyter
*.ipynb
.ipynb_checkpoints/

# Build artifacts
dist/
build/
*.egg-info/
