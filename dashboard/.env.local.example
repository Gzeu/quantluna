# QuantLuna Dashboard — variabile de mediu
# Copiază în .env.local și ajustează valorile
#
#   cp dashboard/.env.local.example dashboard/.env.local

# URL-ul API FastAPI (fără slash final)
# - local:      http://localhost:8000
# - Docker:     http://api:8000  (dacă rulezi în același docker-compose network)
# - Producție:  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# (opțional) Interval refresh pentru polling hooks, în ms
# NEXT_PUBLIC_POLL_INTERVAL_MS=10000
