# ============================================================
# QuantLuna — Production .env template (mainnet minimal capital)
# Copiază în .env şi completează valorile marcate cu <FILL_ME>
# chmod 600 .env  după completare!
# ============================================================

# ---------------------------------------------------------------
# Environment guard  [CRITIC — nu schimba fără să știi ce faci]
# ---------------------------------------------------------------
QUANTLUNA_ENV=production
DRY_RUN=false

# ---------------------------------------------------------------
# Binance Futures API
# ---------------------------------------------------------------
BINANCE_API_KEY=<FILL_ME>
BINANCE_API_SECRET=<FILL_ME>
BINANCE_TESTNET=false

# ---------------------------------------------------------------
# Capital (USDT)
# ---------------------------------------------------------------
CAPITAL_USDT=200
MAX_CAPITAL_USDT=500
MIN_CAPITAL_FLOOR_USDT=50

# ---------------------------------------------------------------
# Strategy
# ---------------------------------------------------------------
SYM_Y=BTCUSDT
SYM_X=ETHUSDT
BAR_FREQ=1h
ZSCORE_ENTRY=2.0
ZSCORE_EXIT=0.5
ZSCORE_WINDOW=50
KALMAN_DELTA=0.0001
WARM_UP_BARS=200

# ---------------------------------------------------------------
# Risk
# ---------------------------------------------------------------
MAX_LEVERAGE=2.0
KELLY_FRACTION=0.15
VOL_TARGET=0.008
MAX_DRAWDOWN_HALT_PCT=0.08
MAX_POSITION_PCT=0.30
DAILY_LOSS_LIMIT_USDT=20

# ---------------------------------------------------------------
# Execution costs (Binance Futures mainnet)
# ---------------------------------------------------------------
FEE_RATE=0.00045
SLIPPAGE_PCT=0.0008
FUNDING_INTERVAL_H=8

# ---------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<FILL_ME>
TELEGRAM_CHAT_ID=<FILL_ME>
NOTIFY_ON_TRADE=true
NOTIFY_ON_HALT=true
NOTIFY_ON_ERROR=true

# ---------------------------------------------------------------
# API server
# ---------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=2

# ---------------------------------------------------------------
# Logging
# ---------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/quantluna.log
LOG_ROTATION=50MB
LOG_RETENTION=30

# ---------------------------------------------------------------
# Kill-switch  [setează true + restart pentru close all positions]
# ---------------------------------------------------------------
EMERGENCY_CLOSE_ALL=false
